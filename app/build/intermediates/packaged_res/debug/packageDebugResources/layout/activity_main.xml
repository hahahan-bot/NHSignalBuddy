<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NHSignalBuddy"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/headerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/macroFileStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textColor="#37474F"
            android:text="macro: —" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/pickMacroFileBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="macro JSON 파일 선택" />

            <Button
                android:id="@+id/clearMacroUriBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내장으로" />
        </LinearLayout>

        <Button
            android:id="@+id/pickMacroTreeBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="kiwoom 폴더 선택 (Syncthing·트리)" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/refreshMacroFileBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="macro 새로고침" />

            <CheckBox
                android:id="@+id/autoRefreshMacroCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="12sp"
                android:text="시작 시 자동" />
        </LinearLayout>

        <TextView
            android:id="@+id/grokSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="12sp"
            android:textColor="#263238"
            android:lineSpacingExtra="2dp"
            android:text="[Grok·macro 요약]" />

        <TextView
            android:id="@+id/trendPicksText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textColor="#37474F"
            android:lineSpacingExtra="2dp"
            android:text="[트렌드 유리 종목]" />

        <TextView
            android:id="@+id/signalsFileStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="12sp"
            android:textColor="#37474F"
            android:text="signals: —" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="GitHub Pages 시그널 URL (비우면 Yahoo·assets)"
            android:textSize="12sp"
            android:textColor="#37474F" />

        <EditText
            android:id="@+id/signalRemoteUrlEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://username.github.io/repo/signals_latest.json"
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/pickSignalsFileBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="시그널 JSON 선택" />

            <Button
                android:id="@+id/clearSignalsFileBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yahoo로" />
        </LinearLayout>

        <Button
            android:id="@+id/refreshSignalsDataBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="시그널 갱신" />

        <Button
            android:id="@+id/editWatchlistBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Watchlist 편집" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:text="종목 줄을 탭하면 매수 평균가·수량 입력 (NH 체결 후 수동 반영)" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/signalList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/signalRemoteFetchTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="11sp"
            android:textColor="#78909C"
            android:visibility="gone" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
